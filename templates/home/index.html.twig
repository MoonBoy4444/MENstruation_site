{% extends 'base.html.twig' %}
{% block title %}Accueil — Ma Boutique{% endblock %}

{% block body %}
<div class="py-5 text-center bg-light rounded-3 mb-5">
    <h1 class="display-5 fw-bold">Bienvenue sur Ma Boutique</h1>
    <p class="col-lg-8 mx-auto fs-5 text-muted">Découvrez notre sélection de produits de qualité.</p>
    <form class="d-flex justify-content-center mt-3" action="{{ path('app_home') }}" method="get">
        <div class="input-group w-50">
            <input class="form-control form-control-lg" type="search" name="q" placeholder="Que recherchez-vous ?">
            <button class="btn btn-dark btn-lg" type="submit"><i class="bi bi-search"></i> Rechercher</button>
        </div>
    </form>
</div>

<h2 class="mb-4">Nouveautés</h2>
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
    {% for produit in produitsVedette %}
        {% include 'produit/_card.html.twig' %}
    {% else %}
        <p class="text-muted">Aucun produit disponible.</p>
    {% endfor %}
</div>
{% endblock %}