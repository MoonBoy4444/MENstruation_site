{% extends 'base.html.twig' %}
{% block title %}Produits — Ma Boutique{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-3">
        <div class="card p-3 mb-4">
            <h5 class="mb-3"><i class="bi bi-funnel"></i> Filtres</h5>
            {{ form_start(filtreForm) }}
                <div class="mb-3">{{ form_label(filtreForm.q) }}{{ form_widget(filtreForm.q, {attr: {class: 'form-control'}}) }}</div>
                <div class="mb-3">{{ form_label(filtreForm.type) }}{{ form_widget(filtreForm.type, {attr: {class: 'form-select'}}) }}</div>
                <div class="mb-3 row g-2">
                    <div class="col">{{ form_label(filtreForm.prixMin) }}{{ form_widget(filtreForm.prixMin, {attr: {class: 'form-control'}}) }}</div>
                    <div class="col">{{ form_label(filtreForm.prixMax) }}{{ form_widget(filtreForm.prixMax, {attr: {class: 'form-control'}}) }}</div>
                </div>
                <div class="mb-3">{{ form_label(filtreForm.sort) }}{{ form_widget(filtreForm.sort, {attr: {class: 'form-select'}}) }}</div>
                {{ form_widget(filtreForm.filtrer, {attr: {class: 'btn btn-dark w-100'}}) }}
            {{ form_end(filtreForm) }}
        </div>
    </div>

    <div class="col-md-9">
        {% if searchQuery %}
            <p class="text-muted">Résultats pour <strong>« {{ searchQuery }} »</strong> — {{ produits|length }} produit(s)</p>
        {% endif %}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            {% for produit in produits %}
                {% include 'produit/_card.html.twig' %}
            {% else %}
                <div class="col-12"><p class="text-muted">Aucun produit trouvé.</p></div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}