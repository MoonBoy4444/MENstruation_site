<div class="col">
    <div class="card h-100 card-produit">
        {% if produit.imageProd %}
            <img src="{{ asset('uploads/produits/' ~ produit.imageProd) }}"
                 class="card-img-top" alt="{{ produit.nomProd }}" style="height:220px;object-fit:cover;">
        {% else %}
            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:220px;">
                <i class="bi bi-image text-white fs-1"></i>
            </div>
        {% endif %}
        <div class="card-body d-flex flex-column">
            <h6 class="card-title mb-1">{{ produit.nomProd }}</h6>
            {% if produit.typeProduit %}
                <span class="badge bg-secondary mb-2">{{ produit.typeProduit.nomTypeProd }}</span>
            {% endif %}
            {% set note = produit.noteMoyenne %}
            {% if note %}
                <div class="star-rating mb-1" style="font-size:.85rem;">
                    {% for i in 1..5 %}
                        <i class="bi bi-star{{ i <= note|round ? '-fill' : '' }}"></i>
                    {% endfor %}
                    <small class="text-muted">({{ produit.avis|length }})</small>
                </div>
            {% endif %}
            <p class="fw-bold fs-5 mt-auto mb-1">{{ produit.prixProd|number_format(2, ',', ' ') }} €</p>
            {% if produit.stockProd == 0 %}
                <span class="badge bg-danger">Rupture de stock</span>
            {% endif %}
            <a href="{{ path('app_produit_show', {id: produit.id}) }}" class="btn btn-dark btn-sm mt-2 stretched-link">
                Voir le produit
            </a>
        </div>
    </div>
</div>