{% extends 'base.html.twig' %}
{% block title %}Mes avis{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-3">
        <div class="list-group mb-4">
            <a href="{{ path('app_compte') }}" class="list-group-item list-group-item-action"><i class="bi bi-person me-2"></i>Mon profil</a>
            <a href="{{ path('app_compte_commandes') }}" class="list-group-item list-group-item-action"><i class="bi bi-box me-2"></i>Mes commandes</a>
            <a href="{{ path('app_compte_avis') }}" class="list-group-item list-group-item-action active"><i class="bi bi-star me-2"></i>Mes avis</a>
            <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a>
        </div>
    </div>
    <div class="col-md-9">
        <h2 class="mb-4">Mes avis ({{ avis|length }})</h2>
        {% for a in avis %}
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">{{ a.titreAvis }}</h6>
                            <a href="{{ path('app_produit_show', {id: a.produit.idProd}) }}" class="text-muted small">
                                {{ a.produit.nomProd }}
                            </a>
                        </div>
                        <div class="text-end">
                            <div class="star-rating">{% for i in 1..5 %}<i class="bi bi-star{{ i <= a.noteAvis ? '-fill' : '' }}"></i>{% endfor %}</div>
                            <small class="text-muted d-block">{{ a.dateAvis|date('d/m/Y') }}</small>
                        </div>
                    </div>
                    <p class="mt-2 mb-2">{{ a.msgAvis }}</p>
                    <form method="post" action="{{ path('app_compte_avis_delete', {id: a.idAvis}) }}"
                          onsubmit="return confirm('Supprimer cet avis ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_avis_' ~ a.idAvis) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i> Supprimer
                        </button>
                    </form>
                </div>
            </div>
        {% else %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-chat-square-text fs-1"></i>
                <p class="mt-3">Vous n'avez encore laissé aucun avis.</p>
                <a href="{{ path('app_produits') }}" class="btn btn-dark">Découvrir nos produits</a>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}