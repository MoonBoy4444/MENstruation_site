{% extends 'base.html.twig' %}
{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-3">
        <div class="list-group mb-4">
            <a href="{{ path('app_compte') }}" class="list-group-item list-group-item-action active"><i class="bi bi-person me-2"></i>Mon profil</a>
            <a href="{{ path('app_compte_commandes') }}" class="list-group-item list-group-item-action"><i class="bi bi-box me-2"></i>Mes commandes</a>
            <a href="{{ path('app_compte_avis') }}" class="list-group-item list-group-item-action"><i class="bi bi-star me-2"></i>Mes avis</a>
            <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a>
        </div>
    </div>
    <div class="col-md-9">
        <h2 class="mb-4">Mon profil</h2>
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Nom complet</dt>
                    <dd class="col-sm-8">{{ client.prenomCli }} {{ client.nomCli }}</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">{{ client.mailCli }}</dd>
                    <dt class="col-sm-4">Téléphone</dt>
                    <dd class="col-sm-8">{{ client.telCli ?: '—' }}</dd>
                    <dt class="col-sm-4">Date de naissance</dt>
                    <dd class="col-sm-8">{{ client.dateNaissanceCli ? client.dateNaissanceCli|date('d/m/Y') : '—' }}</dd>
                </dl>
            </div>
        </div>

        <h4 class="mt-4">Mes adresses</h4>
        {% if client.adresses is empty %}
            <p class="text-muted">Aucune adresse enregistrée.</p>
        {% else %}
            <div class="row g-3">
                {% for adresse in client.adresses %}
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <span class="badge bg-secondary mb-2">{{ adresse.typeAddr }}</span>
                                <p class="mb-0">{{ adresse.rueAddr }}<br>{{ adresse.cpAddr }} {{ adresse.villeAddr }}<br>{{ adresse.paysAddr }}</p>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}