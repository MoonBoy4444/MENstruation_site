{% extends 'base.html.twig' %}
{% block title %}Connexion{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="mb-4 text-center">Connexion</h2>
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}
                <form method="post" action="{{ path('app_login') }}">
                    <div class="mb-3">
                        <label class="form-label">Adresse email</label>
                        <input class="form-control" type="email" name="mailCli" value="{{ last_username }}" autofocus required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mot de passe</label>
                        <input class="form-control" type="password" name="password" required>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="_remember_me" id="remember">
                        <label class="form-check-label" for="remember">Se souvenir de moi</label>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button class="btn btn-dark w-100" type="submit">Se connecter</button>
                </form>
                <hr>
                <p class="text-center mb-0">
                    Pas encore de compte ? <a href="{{ path('app_inscription') }}">S'inscrire</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}