{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="mb-4 text-center">Créer un compte</h2>
                {{ form_start(inscriptionForm, {attr: {novalidate: 'novalidate'}}) }}
                    <div class="row g-3 mb-3">
                        <div class="col">{{ form_label(inscriptionForm.prenomCli) }}{{ form_widget(inscriptionForm.prenomCli, {attr: {class: 'form-control'}}) }}{{ form_errors(inscriptionForm.prenomCli) }}</div>
                        <div class="col">{{ form_label(inscriptionForm.nomCli) }}{{ form_widget(inscriptionForm.nomCli, {attr: {class: 'form-control'}}) }}{{ form_errors(inscriptionForm.nomCli) }}</div>
                    </div>
                    <div class="mb-3">{{ form_label(inscriptionForm.mailCli) }}{{ form_widget(inscriptionForm.mailCli, {attr: {class: 'form-control'}}) }}{{ form_errors(inscriptionForm.mailCli) }}</div>
                    <div class="mb-3">{{ form_label(inscriptionForm.telCli) }}{{ form_widget(inscriptionForm.telCli, {attr: {class: 'form-control'}}) }}</div>
                    <div class="mb-3">{{ form_label(inscriptionForm.dateNaissanceCli) }}{{ form_widget(inscriptionForm.dateNaissanceCli, {attr: {class: 'form-control'}}) }}</div>
                    <div class="mb-3">{{ form_label(inscriptionForm.plainPassword.first) }}{{ form_widget(inscriptionForm.plainPassword.first, {attr: {class: 'form-control'}}) }}{{ form_errors(inscriptionForm.plainPassword) }}</div>
                    <div class="mb-3">{{ form_label(inscriptionForm.plainPassword.second) }}{{ form_widget(inscriptionForm.plainPassword.second, {attr: {class: 'form-control'}}) }}</div>
                    <button class="btn btn-dark w-100" type="submit">Créer mon compte</button>
                {{ form_end(inscriptionForm) }}
                <hr>
                <p class="text-center mb-0">Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a></p>
            </div>
        </div>
    </div>
</div>
{% endblock %}