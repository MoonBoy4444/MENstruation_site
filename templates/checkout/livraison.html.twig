{% extends 'base.html.twig' %}
{% block title %}Mode de livraison{% endblock %}

{% block body %}
{% include 'checkout/_steps.html.twig' %}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h3 class="mb-4"><i class="bi bi-truck me-2"></i>Mode de livraison</h3>

        <div class="card mb-4">
            <div class="card-body">
                {{ form_start(form) }}
                <div class="mb-4">
                    {% for child in form.livraison %}
                        <div class="form-check p-3 border rounded mb-2
                                    {{ loop.first ? 'border-dark' : '' }}">
                            {{ form_widget(child, {attr: {class: 'form-check-input'}}) }}
                            {{ form_label(child, null, {label_attr: {class: 'form-check-label w-100 ms-2'}}) }}
                        </div>
                    {% endfor %}
                    {{ form_errors(form.livraison) }}
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_checkout_adresse') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Retour
                    </a>
                    {{ form_widget(form.suivant, {attr: {class: 'btn btn-dark btn-lg px-5'}}) }}
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        {% include 'checkout/_recap.html.twig' %}
    </div>
</div>
{% endblock %}