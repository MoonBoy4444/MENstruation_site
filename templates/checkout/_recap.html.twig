{# templates/checkout/_recap.html.twig #}
<div class="card border-0 shadow-sm sticky-top" style="top:20px;">
    <div class="card-header bg-dark text-white">
        <strong><i class="bi bi-receipt me-1"></i> Récapitulatif</strong>
    </div>
    <div class="card-body p-0">
        {% for item in items %}
            <div class="d-flex align-items-center gap-2 p-3 border-bottom">
                {% if item.produit.imageProd %}
                    <img src="{{ asset('uploads/produits/' ~ item.produit.imageProd) }}"
                         style="width:45px;height:45px;object-fit:cover;border-radius:4px;" alt="">
                {% endif %}
                <div class="flex-grow-1 small">
                    <div class="fw-semibold">{{ item.produit.nomProd }}</div>
                    <div class="text-muted">× {{ item.quantite }}</div>
                </div>
                <div class="fw-bold small">{{ item.sousTotal|number_format(2, ',', ' ') }} €</div>
            </div>
        {% endfor %}
    </div>
    <div class="card-footer">
        <div class="d-flex justify-content-between text-muted small mb-1">
            <span>Sous-total</span>
            <span>{{ total|number_format(2, ',', ' ') }} €</span>
        </div>
        {% if livraison is defined and livraison %}
            <div class="d-flex justify-content-between text-muted small mb-2">
                <span>{{ livraison.nomLivr }}</span>
                <span>{{ livraison.fraisLivr|number_format(2, ',', ' ') }} €</span>
            </div>
            <hr class="my-2">
            <div class="d-flex justify-content-between fw-bold">
                <span>Total</span>
                <span>{{ (total + livraison.fraisLivr)|number_format(2, ',', ' ') }} €</span>
            </div>
        {% else %}
            <hr class="my-2">
            <div class="d-flex justify-content-between fw-bold">
                <span>Total (hors livraison)</span>
                <span>{{ total|number_format(2, ',', ' ') }} €</span>
            </div>
        {% endif %}
    </div>
</div>