{% extends 'base.html.twig' %}
{% block title %}Mon panier{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <h2 class="mb-4"><i class="bi bi-cart3"></i> Mon panier</h2>

        {% if items is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-cart-x" style="font-size:4rem;"></i>
                <p class="mt-3 fs-5">Votre panier est vide.</p>
                <a href="{{ path('app_produits') }}" class="btn btn-dark mt-2">
                    <i class="bi bi-bag me-1"></i> Découvrir nos produits
                </a>
            </div>
        {% else %}
            <div class="card mb-3">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Produit</th>
                                <th class="text-center" style="width:140px;">Quantité</th>
                                <th class="text-end">Prix unit.</th>
                                <th class="text-end pe-3">Sous-total</th>
                                <th style="width:50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in items %}
                                {% set produit = item.produit %}
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-3">
                                            {% if produit.imageProd %}
                                                <img src="{{ asset('uploads/produits/' ~ produit.imageProd) }}"
                                                     alt="{{ produit.nomProd }}"
                                                     style="width:60px;height:60px;object-fit:cover;border-radius:6px;">
                                            {% endif %}
                                            <div>
                                                <a href="{{ path('app_produit_show', {id: produit.idProd}) }}"
                                                   class="fw-semibold text-dark text-decoration-none">
                                                    {{ produit.nomProd }}
                                                </a>
                                                <div class="text-muted small">Réf. {{ produit.refProd }}</div>
                                                {% if produit.stockProd < item.quantite %}
                                                    <span class="badge bg-warning text-dark">
                                                        Stock limité : {{ produit.stockProd }} dispo.
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <form method="post"
                                              action="{{ path('app_cart_update', {id: produit.idProd}) }}"
                                              class="d-flex align-items-center justify-content-center gap-1">
                                            <button type="submit" name="quantite"
                                                    value="{{ item.quantite - 1 }}"
                                                    class="btn btn-sm btn-outline-secondary px-2">
                                                <i class="bi bi-dash"></i>
                                            </button>
                                            <span class="fw-bold px-2">{{ item.quantite }}</span>
                                            <button type="submit" name="quantite"
                                                    {# value="{{ [item.quantite + 1, produit.stockProd]|min }}" #}
                                                    class="btn btn-sm btn-outline-secondary px-2"
                                                    {% if item.quantite >= produit.stockProd %}disabled{% endif %}>
                                                <i class="bi bi-plus"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="text-end">
                                        {{ produit.prixProd|number_format(2, ',', ' ') }} €
                                    </td>
                                    <td class="text-end pe-3 fw-bold">
                                        {{ item.sousTotal|number_format(2, ',', ' ') }} €
                                    </td>
                                    <td>
                                        <form method="post"
                                              action="{{ path('app_cart_remove', {id: produit.idProd}) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <form method="post" action="{{ path('app_cart_clear') }}"
                  onsubmit="return confirm('Vider le panier ?')">
                <button type="submit" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-trash me-1"></i> Vider le panier
                </button>
            </form>
        {% endif %}
    </div>

    {% if items is not empty %}
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm sticky-top" style="top:20px;">
            <div class="card-body">
                <h5 class="mb-4">Récapitulatif</h5>

                <div class="d-flex justify-content-between mb-2 text-muted">
                    <span>Sous-total</span>
                    <span>{{ total|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="d-flex justify-content-between mb-2 text-muted">
                    <span>Livraison</span>
                    <span class="text-success">Calculée à l'étape suivante</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                    <span>Total estimé</span>
                    <span>{{ total|number_format(2, ',', ' ') }} €</span>
                </div>

                {% if app.user %}
                    <a href="{{ path('app_checkout_adresse') }}"
                       class="btn btn-dark w-100 btn-lg">
                        <i class="bi bi-lock me-1"></i> Commander
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}"
                       class="btn btn-dark w-100 btn-lg mb-2">
                        <i class="bi bi-person me-1"></i> Se connecter pour commander
                    </a>
                    <a href="{{ path('app_inscription') }}"
                       class="btn btn-outline-dark w-100">
                        Créer un compte
                    </a>
                {% endif %}

                <a href="{{ path('app_produits') }}" class="btn btn-link w-100 mt-2 text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Continuer mes achats
                </a>

                <div class="mt-3 pt-3 border-top small text-muted text-center">
                    <i class="bi bi-shield-lock me-1"></i> Paiement 100% sécurisé<br>
                    <i class="bi bi-arrow-return-left me-1"></i> Retours gratuits 30 jours
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}